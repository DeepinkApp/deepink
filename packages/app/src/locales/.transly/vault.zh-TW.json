	"creator.section.kdf.description": {
		"hash": "5a25839414378ad1f34ca43cd6d6e4b0a11dc292f0b129cdfca5ba38a6897059",
		"translation": "通過延長每次嘗試的時間和成本來幫助保護弱或重複使用的密碼。提高這些設置以增強保護，或者保留預設以獲得平衡的體驗。"
	},
	"creator.section.kdf.memory.label": {
		"hash": "46e2c42a0c19ddf30ba473d20d61e77aa70357a3ce2e24acd8ce118cc93091b4",
		"translation": "內存使用"
	},
	"creator.section.kdf.memory.description": {
		"hash": "9ab4ecaa6df9b3bbca7779ac7796f9f12c339f6bf882b6604dcd4e5143ada9ef",
		"translation": "使每次密碼猜測使用更多內存。這對於大規模攻擊特別有效，因為內存成本高且比原始計算更難高效擴展。"
	},
	"creator.section.kdf.ops.label": {
		"hash": "4740b573715316a4698d4dee44ebb90046ed94f5f582ffa67ccab31e68a8a6b5",
		"translation": "迭代次數"
	},
	"creator.section.kdf.ops.description": {
		"hash": "7e94dc647e2940108ebafd7edd4b77f1b21f7c8099b1ad84390d5ab9c27c7013",
		"translation": "為每次密碼猜測重複導出工作。這以大致線性的方式增加每次猜測的成本：將迭代次數加倍大約會使攻擊者和您的設備的工作量都加倍。"
	}
}
